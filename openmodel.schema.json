{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/macedot/openmodel/master/openmodel.schema.json",
  "title": "OpenModel Configuration",
  "description": "Configuration schema for OpenModel server",
  "type": "object",
  "required": ["server", "providers", "models"],
  "properties": {
    "server": {
      "type": "object",
      "description": "Server settings",
      "required": ["port", "host"],
      "properties": {
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "default": 12345,
          "description": "Port to listen on"
        },
        "host": {
          "type": "string",
          "default": "localhost",
          "description": "Host to bind to"
        }
      }
    },
    "providers": {
      "type": "object",
      "description": "Map of provider names to provider configurations",
      "additionalProperties": {
        "type": "object",
        "required": ["url"],
        "properties": {
          "url": {
            "type": "string",
            "description": "Base URL for the OpenAI-compatible API"
          },
          "api_key": {
            "type": "string",
            "description": "API key for authentication (supports ${VAR} expansion)"
          },
          "models": {
            "type": "array",
            "items": {
              "type": "string",
              "description": "Model name available on this provider"
            },
            "description": "List of models available on this provider (used for own model resolution)"
          },
          "thresholds": {
            "type": "object",
            "description": "Failure threshold settings for this provider (overrides global thresholds)",
            "properties": {
              "failures_before_switch": {
                "type": "integer",
                "minimum": 1,
                "default": 3,
                "description": "Number of failures before switching to next provider"
              },
              "initial_timeout_ms": {
                "type": "integer",
                "minimum": 0,
                "default": 10000,
                "description": "Initial timeout in milliseconds"
              },
              "max_timeout_ms": {
                "type": "integer",
                "minimum": 0,
                "default": 300000,
                "description": "Maximum timeout in milliseconds"
              }
            }
          }
        }
      }
    },
    "models": {
      "type": "object",
      "description": "Map of model aliases to their provider configurations. Use 'provider/model' for explicit mapping or just 'modelname' to auto-resolve from provider's models list.",
      "additionalProperties": {
        "oneOf": [
          {
            "type": "array",
            "items": {
              "oneOf": [
                {
                  "type": "string",
                  "pattern": "^[^/]+/[^/]+$",
                  "description": "Model in 'provider/model' format"
                },
                {
                  "type": "string",
                  "pattern": "^[^/]+$",
                  "description": "Own model name (auto-resolved to first provider with this model)"
                },
                {
                  "type": "object",
                  "required": ["provider", "model"],
                  "properties": {
                    "provider": {
                      "type": "string",
                      "description": "Name of the provider from providers config"
                    },
                    "model": {
                      "type": "string",
                      "description": "Model name on that provider"
                    }
                  }
                }
              ]
            }
          },
          {
            "type": "object",
            "required": ["providers"],
            "properties": {
              "strategy": {
                "type": "string",
                "enum": ["fallback", "round-robin", "random"],
                "default": "fallback",
                "description": "Selection strategy for this model"
              },
              "api_mode": {
                "type": "string",
                "enum": ["openai", "anthropic", ""],
                "default": "",
                "description": "API format conversion mode: 'openai' for OpenAI format, 'anthropic' for Anthropic format, empty for passthrough"
              },
              "default": {
                "type": "boolean",
                "default": false,
                "description": "If true, this model is the default when no model is specified"
              },
              "providers": {
                "type": "array",
                "items": {
                  "oneOf": [
                    {
                      "type": "string",
                      "pattern": "^[^/]+/[^/]+$",
                      "description": "Model in 'provider/model' format"
                    },
                    {
                      "type": "string",
                      "pattern": "^[^/]+$",
                      "description": "Own model name"
                    },
                    {
                      "type": "object",
                      "required": ["provider", "model"],
                      "properties": {
                        "provider": {
                          "type": "string"
                        },
                        "model": {
                          "type": "string"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        ]
      }
    },
    "thresholds": {
      "type": "object",
      "description": "Default failure threshold settings (used as fallback when provider-specific thresholds not set)",
      "properties": {
        "failures_before_switch": {
          "type": "integer",
          "minimum": 1,
          "default": 3,
          "description": "Number of failures before switching to next provider"
        },
        "initial_timeout_ms": {
          "type": "integer",
          "minimum": 0,
          "default": 10000,
          "description": "Initial timeout in milliseconds"
        },
        "max_timeout_ms": {
          "type": "integer",
          "minimum": 0,
          "default": 300000,
          "description": "Maximum timeout in milliseconds"
        }
      }
    },
    "log_level": {
      "type": "string",
      "enum": ["trace", "debug", "info", "warn", "error"],
      "default": "info",
      "description": "Logging level"
    },
    "log_format": {
      "type": "string",
      "enum": ["text", "color", "json"],
      "default": "color",
      "description": "Log output format (color for colored terminal output)"
    },
    "rate_limit": {
      "type": "object",
      "description": "Rate limiting configuration for the server",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable per-IP rate limiting"
        },
        "requests_per_second": {
          "type": "integer",
          "minimum": 1,
          "default": 10,
          "description": "Maximum requests per second per IP"
        },
        "burst": {
          "type": "integer",
          "minimum": 1,
          "default": 20,
          "description": "Maximum burst size for rate limiting"
        },
        "cleanup_interval_ms": {
          "type": "integer",
          "minimum": 1000,
          "default": 60000,
          "description": "Interval in milliseconds for cleaning up stale entries"
        },
        "trusted_proxies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": ["127.0.0.1", "::1"],
          "description": "List of trusted proxy IP ranges (CIDR notation supported)"
        }
      }
    },
    "http": {
      "type": "object",
      "description": "HTTP client configuration",
      "properties": {
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "default": 120,
          "description": "Request timeout in seconds"
        },
        "max_idle_conns": {
          "type": "integer",
          "minimum": 0,
          "default": 100,
          "description": "Maximum number of idle connections"
        },
        "max_idle_conns_per_host": {
          "type": "integer",
          "minimum": 0,
          "default": 100,
          "description": "Maximum idle connections per host"
        },
        "idle_conn_timeout_seconds": {
          "type": "integer",
          "minimum": 0,
          "default": 90,
          "description": "Idle connection timeout in seconds"
        },
        "dial_timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "default": 10,
          "description": "Dial timeout in seconds"
        },
        "tls_handshake_timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "default": 10,
          "description": "TLS handshake timeout in seconds"
        },
        "response_header_timeout_seconds": {
          "type": "integer",
          "minimum": 0,
          "default": 30,
          "description": "Response header timeout in seconds"
        }
      }
    },
    "limits": {
      "type": "object",
      "description": "Request/response size limits",
      "properties": {
        "max_request_body_bytes": {
          "type": "integer",
          "minimum": 0,
          "default": 52428800,
          "description": "Maximum request body size in bytes (default: 50MB)"
        },
        "max_response_body_bytes": {
          "type": "integer",
          "minimum": 0,
          "default": 1048576,
          "description": "Maximum response body size in bytes (default: 1MB)"
        },
        "max_stream_buffer_bytes": {
          "type": "integer",
          "minimum": 0,
          "default": 1048576,
          "description": "Maximum stream buffer size in bytes (default: 1MB)"
        }
      }
    }
  }
}
